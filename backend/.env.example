# Database
MONGODB_URI=mongodb://localhost:27017/ai-recruiter-platform

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=ai-recruiter-platform

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Password Hashing
BCRYPT_SALT_ROUNDS=12

# File Upload Configuration
UPLOAD_PATH=./uploads

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# AI Services
OPENAI_API_KEY=your-openai-api-key
VAPI_API_KEY=your-vapi-api-key
VAPI_WEBHOOK_URL=http://localhost:5000/api/voice/webhook
DEFAULT_AI_PROVIDER=openai

# Email Configuration (choose one)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-app-password
EMAIL_FROM=AI Recruiter Platform <noreply@ai-recruiter.com>

# Alternative: SMTP Configuration
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password

# Alternative: SendGrid Configuration
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=your-sendgrid-api-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
CORS_ORIGIN=http://localhost:3000